
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Replace this with your project-specific Supabase URL from the dashboard.
# Example: SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_URL=your_supabase_url

NOMBA_BASE_URL=https://api.nomba.com
NOMBA_SANDBOX_URL=https://sandbox.nomba.com
Main_Account_ID=your_nomba_main_account_id
NOMBA_SUB_ACCOUNT_ID=your_nomba_sub_account_id
NOMBA_LIVE_CLIENT_ID=your_nomba_live_client_id
NOMBA_LIVE_PRIVATE_KEY=your_nomba_live_private_key
NOMBA_SIGNATURE=your_nomba_webhook_signature_key

ENABLE_KEEP_ALIVE=true
ENABLE_AUTO_ACTIVATION=true
ENABLE_GROUP_COLLECTION_CRON=true
ENABLE_NOMBA_HISTORY_SYNC=false
KEEP_ALIVE_INTERVAL_SECONDS=600
AUTO_ACTIVATE_INTERVAL_SECONDS=300
GROUP_COLLECTION_INTERVAL_SECONDS=300
NOMBA_HISTORY_SYNC_INTERVAL_SECONDS=86400
NOMBA_HISTORY_DAYS_BACK=7





